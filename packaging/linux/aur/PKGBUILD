# Maintainer: Vedant Parikh <vedant.parikh@glib.ai>
pkgname=pdfpixel
pkgver=0.2.1
pkgrel=1
pkgdesc="Right-click a PDF -> every page as a PNG. Adds a 'Convert to Images' menu to GNOME Files / Nemo / Caja / Dolphin."
arch=('any')
url="https://github.com/parikhvedant2003/PDFPixel"
license=('MIT')
depends=('python' 'python-pillow' 'python-pypdfium2' 'libnotify' 'tk')
optdepends=(
  'python-nautilus: right-click entry in GNOME Files'
  'python-nemo: right-click entry in Nemo (Cinnamon)'
  'python-caja: right-click entry in Caja (MATE)'
)
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')  # run `updpkgsums` to pin, then regenerate .SRCINFO

build() {
  cd "PDFPixel-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "PDFPixel-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl

  # MIT license
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  # File-manager extensions (native install -> full right-click integration,
  # unlike the sandboxed Flatpak/Snap which cannot touch the host file manager).
  install -Dm644 integrations/linux/pdfpixel_nautilus.py \
    "$pkgdir/usr/share/nautilus-python/extensions/pdfpixel.py"
  install -Dm644 integrations/linux/pdfpixel_nemo.py \
    "$pkgdir/usr/share/nemo-python/extensions/pdfpixel.py"
  install -Dm644 integrations/linux/pdfpixel_caja.py \
    "$pkgdir/usr/share/caja-python/extensions/pdfpixel.py"

  # KDE Dolphin ServiceMenu
  install -Dm644 integrations/linux/pdfpixel.desktop \
    "$pkgdir/usr/share/kio/servicemenus/pdfpixel.desktop"
}
